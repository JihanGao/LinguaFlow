# PostgreSQL (Neon, Supabase, Railway, local Docker, etc.). Use sslmode=require on hosted providers.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# One-time SQLite → Postgres row copy (optional). Default file: prisma/dev.db
# SQLITE_DATABASE_PATH=prisma/dev.db
OPENAI_API_KEY=""
# Optional: OpenAI-compatible API root (e.g. http://127.0.0.1:8000/v1 for oMLX). Omit for api.openai.com.
# OPENAI_BASE_URL="http://127.0.0.1:8000/v1"
OPENAI_MODEL_DEFAULT="gpt-5-mini"
# Used when the primary model returns empty text (common if max_completion_tokens is too low for reasoning models)
OPENAI_MODEL_FALLBACK="gpt-4.1-mini"
OPENAI_MODEL_HIGH_QUALITY="gpt-5.4"
OPENAI_REASONING_DEFAULT="medium"
OPENAI_REASONING_HIGH_QUALITY="high"

# Production screenshots: Vercel Blob (Dashboard → Storage → Create → link env). Omit locally to use public/uploads.
# BLOB_READ_WRITE_TOKEN=""
